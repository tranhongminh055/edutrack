<mxfile>
  <diagram name="Use Case Diagram" id="usecase1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== ACTORS ===== -->
        <!-- Sinh Viên -->
        <mxCell id="actor_student" value="Sinh Viên" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="180" width="40" height="60" as="geometry"/>
        </mxCell>
        <!-- Giảng Viên -->
        <mxCell id="actor_lecturer" value="Giảng Viên" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="420" width="40" height="60" as="geometry"/>
        </mxCell>
        <!-- Admin -->
        <mxCell id="actor_admin" value="Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="660" width="40" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== PACKAGE 1: Xác thực & Tài khoản ===== -->
        <mxCell id="pkg1" value="Hệ thống Xác thực &amp; Tài khoản" style="shape=rectangle;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=14;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="180" y="20" width="420" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="uc_login" value="Đăng nhập" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="210" y="70" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_profile" value="Quản lý Hồ sơ" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="210" y="140" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_firebase" value="Xác thực&#xa;Firebase Auth" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_forgot" value="Quên mật khẩu" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="420" y="130" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_manage_acc" value="Duyệt / Khóa&#xa;Tài khoản" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="210" width="150" height="50" as="geometry"/>
        </mxCell>
        <!-- include: Đăng nhập -> Firebase Auth -->
        <mxCell id="inc1" style="html=1;dashed=1;endArrow=open;endSize=12;strokeColor=#b85450;fontColor=#b85450;fontSize=11;" edge="1" parent="1" source="uc_login" target="uc_firebase">
          <mxGeometry relative="1" as="geometry"/>
          <Array as="points"/>
          <mxCell id="inc1_label" value="&lt;&lt;include&gt;&gt;" style="edgeLabel;html=1;fontSize=11;fontColor=#b85450;fontStyle=2;" vertex="1" connectable="0" parent="inc1">
            <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
          </mxCell>
        </mxCell>
        <!-- extend: Quên mật khẩu -> Đăng nhập -->
        <mxCell id="ext1" style="html=1;dashed=1;endArrow=open;endSize=12;strokeColor=#82b366;fontColor=#82b366;fontSize=11;" edge="1" parent="1" source="uc_forgot" target="uc_login">
          <mxGeometry relative="1" as="geometry"/>
          <mxCell id="ext1_label" value="&lt;&lt;extend&gt;&gt;" style="edgeLabel;html=1;fontSize=11;fontColor=#82b366;fontStyle=2;" vertex="1" connectable="0" parent="ext1">
            <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
          </mxCell>
        </mxCell>

        <!-- ===== PACKAGE 2: Học vụ & Tài chính ===== -->
        <mxCell id="pkg2" value="Quản lý Học vụ &amp; Tài chính" style="shape=rectangle;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=14;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="180" y="310" width="420" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="uc_register" value="Đăng ký tín chỉ" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="210" y="360" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_calc" value="Tính toán học phí" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="420" y="350" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_pay" value="Nộp biên lai&#xa;Học phí" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="210" y="430" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_upload" value="Upload ảnh&#xa;biên lai" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="420" y="420" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_approve" value="Duyệt trạng thái&#xa;Học phí" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="500" width="150" height="50" as="geometry"/>
        </mxCell>
        <!-- include: Đăng ký -> Tính toán -->
        <mxCell id="inc2" style="html=1;dashed=1;endArrow=open;endSize=12;strokeColor=#b85450;fontColor=#b85450;fontSize=11;" edge="1" parent="1" source="uc_register" target="uc_calc">
          <mxGeometry relative="1" as="geometry"/>
          <mxCell id="inc2_label" value="&lt;&lt;include&gt;&gt;" style="edgeLabel;html=1;fontSize=11;fontColor=#b85450;fontStyle=2;" vertex="1" connectable="0" parent="inc2">
            <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
          </mxCell>
        </mxCell>
        <!-- include: Nộp biên lai -> Upload -->
        <mxCell id="inc3" style="html=1;dashed=1;endArrow=open;endSize=12;strokeColor=#b85450;fontColor=#b85450;fontSize=11;" edge="1" parent="1" source="uc_pay" target="uc_upload">
          <mxGeometry relative="1" as="geometry"/>
          <mxCell id="inc3_label" value="&lt;&lt;include&gt;&gt;" style="edgeLabel;html=1;fontSize=11;fontColor=#b85450;fontStyle=2;" vertex="1" connectable="0" parent="inc3">
            <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
          </mxCell>
        </mxCell>

        <!-- ===== PACKAGE 3: E-Learning ===== -->
        <mxCell id="pkg3" value="E-Learning &amp; Lớp học" style="shape=rectangle;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=14;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="180" y="600" width="420" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="uc_class" value="Quản lý Lớp học" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="210" y="650" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_quiz" value="Tạo Bài kiểm tra" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="210" y="720" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_take" value="Làm bài kiểm tra" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="430" y="650" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_grade" value="Chấm điểm&#xa;&amp; Đánh giá" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="430" y="720" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="uc_view" value="Xem điểm số" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="790" width="150" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== CONNECTIONS: Sinh Viên ===== -->
        <mxCell id="s1" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_student" target="uc_login"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_student" target="uc_profile"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s3" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_student" target="uc_register"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s4" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_student" target="uc_pay"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s5" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_student" target="uc_take"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s6" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_student" target="uc_view"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== CONNECTIONS: Giảng Viên ===== -->
        <mxCell id="l1" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_lecturer" target="uc_login"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_lecturer" target="uc_profile"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l3" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_lecturer" target="uc_class"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l4" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_lecturer" target="uc_quiz"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l5" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_lecturer" target="uc_grade"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== CONNECTIONS: Admin ===== -->
        <mxCell id="a1" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_admin" target="uc_login"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_admin" target="uc_manage_acc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" style="endArrow=none;html=1;strokeWidth=1.5;" edge="1" parent="1" source="actor_admin" target="uc_approve"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
