rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // E-Learning resources: cho phép mọi user đọc/ghi do app React không dùng Firebase Auth
    match /elearning_resources/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 50 * 1024 * 1024;
    }

    // Các path khác
    match /{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
